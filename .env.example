# OpenAI
OPENAI_API_KEY=sk-proj-replace-me

# JWT (HS256). Must be at least 32 characters.
JWT_SIGNING_KEY=change-me-to-a-long-random-string-min-32-chars

# Optional Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Frontend → API base URL (consumed by Vite at build time)
VITE_API_BASE_URL=http://localhost:5001
